{
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "typescript.tsdk": "node_modules/typescript/lib",
  "cSpell.ignorePaths": [
    "pnpm-lock.yaml",
    "node_modules",
    "vscode-extension",
    ".git/{info,lfs,logs,refs,objects}/**",
    ".git/{index,*refs,*HEAD}",
    ".vscode",
    ".vscode-insiders",
    ".gitignore"
  ],
  "cSpell.words": ["Collios", "VITE", "antd", "anticon", "Avenir", "cssinjs", "grayscale", "Linkando", "rgba"],
  "files.associations": {
    "*.css": "tailwindcss"
  },
  "cSpell.enabledFileTypes": {
    "json": false
  }
}
